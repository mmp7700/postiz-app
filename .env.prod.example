# Production environment template for social.itsborderline.com.
# Real .env.prod is gitignored — keep the live values in your password manager.
#
# Workflow:
#   ./scripts/deploy-env.sh pull   # populate .env.prod from prod
#   $EDITOR .env.prod              # edit
#   ./scripts/deploy-env.sh diff   # preview key-level changes (values masked)
#   ./scripts/deploy-env.sh push   # back up remote, sync, recreate postiz container
#
# Only keys listed here are documented as required. Pull from prod to see the
# full current set.

# === URLs ===
FRONTEND_URL="https://social.itsborderline.com"
NEXT_PUBLIC_BACKEND_URL="https://social.itsborderline.com"
BACKEND_INTERNAL_URL="http://postiz:5000"

# === Required infra ===
DATABASE_URL=""
REDIS_URL=""
JWT_SECRET=""

# === Storage (DO Spaces) ===
STORAGE_PROVIDER=""

# === Social OAuth credentials ===
# X / Twitter — OAuth 1.0a Consumer Keys from developer.x.com
X_URL=""
X_API_KEY=""
X_API_SECRET=""

# LinkedIn
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""

# Facebook / Instagram
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
